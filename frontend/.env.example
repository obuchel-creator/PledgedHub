# ==========================================
# PledgeHub Frontend Configuration
# ==========================================

# API Configuration
VITE_API_URL=http://localhost:5001/api
VITE_API_TIMEOUT=30000

# Application Configuration
VITE_APP_NAME=PledgeHub
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Pledge Management System

# Feature Flags
VITE_ENABLE_OAUTH=true
VITE_ENABLE_AI_FEATURES=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_CAMPAIGNS=true
VITE_ENABLE_PAYMENTS=true
VITE_ENABLE_SMS_NOTIFICATIONS=true
VITE_ENABLE_EMAIL_NOTIFICATIONS=true

# OAuth Configuration
VITE_GOOGLE_OAUTH_ENABLED=true
VITE_FACEBOOK_OAUTH_ENABLED=true

# Development Settings
VITE_ENABLE_DEV_TOOLS=true
VITE_ENABLE_DEBUG_LOGGING=false
VITE_DEBUG_AUTH=false
VITE_DEBUG_API=false
VITE_DEBUG_UI=false

# Analytics (Optional)
VITE_GOOGLE_ANALYTICS_ID=
VITE_ENABLE_TRACKING=false

# Appearance
VITE_THEME=light
VITE_BRAND_COLOR=#4F46E5

# Localization
VITE_DEFAULT_LANGUAGE=en
VITE_SUPPORTED_LANGUAGES=en,sw

# Contact Information
VITE_SUPPORT_EMAIL=support@pledgehub.com
VITE_SUPPORT_PHONE=+256700000000
