{
    "name": "pledgehub",
    "version": "1.0.0",
    "description": "PledgeHub — backend + tooling starter (Node + TypeScript) with robust scripts, linting, formatting and testing.",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/your-org/pledgehub.git"
    },
    "author": "",
    "license": "MIT",
    "private": false,
    "engines": {
        "node": ">=14.17.0"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "start": "node dist/index.js",
        "dev": "nodemon backend/server.js",
        "build": "tsc -p tsconfig.json",
        "clean": "rimraf dist",
        "test": "jest --coverage --passWithNoTests && jest --runInBand",
        "test:watch": "jest --watch",
        "lint": "eslint 'src/**/*.{ts,js}' --max-warnings=0",
        "format": "prettier --write \"src/**/*.{ts,js,json,md}\"",
        "prepare": "husky install",
        "prepublishOnly": "npm run build",
        "coverage": "jest --coverage --runInBand"
    },
    "dependencies": {
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2"
    },
    "devDependencies": {
        "@babel/core": "^7.28.5",
        "@babel/preset-env": "^7.28.5",
        "@babel/preset-react": "^7.28.5",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.3",
        "@types/node": "^20.5.1",
        "babel-jest": "^29.7.0",
        "cross-env": "^7.0.3",
        "eslint": "^8.57.1",
        "eslint-config-prettier": "^8.8.0",
        "eslint-plugin-import": "^2.28.1",
        "husky": "^9.1.7",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "lint-staged": "^13.2.4",
        "nodemon": "^2.0.22",
        "prettier": "^2.8.8",
        "rimraf": "^5.0.0",
        "ts-jest": "^29.1.0",
        "ts-node": "^10.9.1",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.3.0"
    },
    "lint-staged": {
        "src/**/*.{ts,js,json,md}": [
            "npm run lint",
            "npm run format"
        ]
    },
    "keywords": [
        "pledgehub",
        "pledge",
        "node",
        "typescript",
        "express",
        "starter"
    ]
}

