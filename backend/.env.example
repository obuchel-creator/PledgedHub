# ==========================================
# PledgeHub Backend Configuration
# ==========================================

# Server Configuration
PORT=5001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
APP_URL=http://localhost:5001

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=your_mysql_password
DB_NAME=pledgehub_db

# Test Database (Optional)
TEST_DB_NAME=pledgehub_test_db

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRES_IN=24h

# Session Secret (for OAuth)
SESSION_SECRET=your_session_secret_key_change_this_in_production_min_32_chars

# ==========================================
# AI Configuration (Google Gemini Pro)
# ==========================================
# Get FREE API key at: https://makersuite.google.com/app/apikey
GOOGLE_AI_API_KEY=your_gemini_api_key_here

# ==========================================
# Email Configuration (SMTP)
# ==========================================
# For Gmail: Use App Password from https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM=your_email@gmail.com
EMAIL_FROM_NAME=PledgeHub System

# ==========================================
# SMS Configuration (Optional)
# ==========================================

# Twilio SMS (International)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ==========================================
# Mobile Money Payment Configuration
# ==========================================

# MTN Mobile Money Uganda
MTN_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_SUBSCRIPTION_KEY=your_mtn_subscription_key
MTN_API_USER=your_mtn_api_user_uuid
MTN_API_KEY=your_mtn_api_key
MTN_CALLBACK_URL=http://localhost:5001/api/payments/mtn/callback
MTN_ENVIRONMENT=sandbox
MTN_MERCHANT_CODE=12345

# Airtel Money Uganda
AIRTEL_BASE_URL=https://openapi.airtel.africa
AIRTEL_CLIENT_ID=your_airtel_client_id
AIRTEL_CLIENT_SECRET=your_airtel_client_secret
AIRTEL_CALLBACK_URL=http://localhost:5001/api/payments/airtel/callback
AIRTEL_ENVIRONMENT=sandbox
AIRTEL_MERCHANT_CODE=67890
# ⭐ IMPORTANT: Set AIRTEL_MERCHANT_ID to YOUR merchant account
AIRTEL_MERCHANT_ID=your_airtel_merchant_id_here

# ==========================================
# PAYOUT & COMMISSION CONFIGURATION
# ==========================================

# Platform Commission (percentage taken from each payment)
PLATFORM_COMMISSION_PERCENT=10

# Default payout settings
DEFAULT_PAYOUT_SCHEDULE=monthly
DEFAULT_PAYOUT_METHOD=bank_transfer
DEFAULT_BANK_CODE=EXIM

# Monthly payout processing day (1-28)
MONTHLY_PAYOUT_DAY=1

# ==========================================
# Security Configuration
# ==========================================

# Encryption Key (32 bytes hex) - Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_256_bit_encryption_key_here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# ==========================================
# Helpline Configuration
# ==========================================
HELPLINE_NUMBER=0800-753343
HELPLINE_SMS=0800753343
# Get credentials from: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Africa's Talking SMS (Africa)
# Get credentials from: https://account.africastalking.com/
AFRICASTALKING_USERNAME=your_africastalking_username
AFRICASTALKING_API_KEY=your_africastalking_api_key
AFRICASTALKING_SENDER_ID=PledgeHub

# MTN Mobile Money (Uganda)
MTN_COLLECTION_USER_ID=your_mtn_user_id
MTN_COLLECTION_API_KEY=your_mtn_api_key
MTN_SUBSCRIPTION_KEY=your_mtn_subscription_key
MTN_CALLBACK_URL=http://localhost:5001/api/payments/mtn/callback

# Airtel Money (Uganda)
AIRTEL_CLIENT_ID=your_airtel_client_id
AIRTEL_CLIENT_SECRET=your_airtel_client_secret
AIRTEL_PIN=your_airtel_pin
AIRTEL_CALLBACK_URL=http://localhost:5001/api/payments/airtel/callback

# ==========================================
# OAuth Configuration (Optional)
# ==========================================

# Google OAuth
# Get credentials from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5001/api/oauth/google/callback

# Facebook OAuth
# Get credentials from: https://developers.facebook.com/
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=http://localhost:5001/api/oauth/facebook/callback

# ==========================================
# Payment Gateway Configuration (Optional)
# ==========================================

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# ==========================================
# Security & Features
# ==========================================
ENABLE_REGISTRATIONS=true
ENABLE_EMAIL_VERIFICATION=false
ENABLE_2FA=false
ENABLE_TEST_MODE=false

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# Logging & Monitoring
# ==========================================
LOG_FORMAT=dev
LOG_LEVEL=info

# Redis (Optional - for session storage)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ==========================================
# Cron Jobs Configuration
# ==========================================
ENABLE_CRON_JOBS=true
CRON_TIMEZONE=Africa/Kampala
CRON_REMINDERS_ENABLED=true
CRON_PAYMENT_TRACKING_ENABLED=true


